#! /usr/bin/env bash
prefix=$1
shift=$(( 32 - prefix ))
# start with 32 bits to 1, shift left to match the /24 , trim extra bits with mask so it stay 32bits
bits=$(( 0xffffffff << shift & 0xffffffff ))

printf "%d.%d.%d.%d\n" \
    $(( (bits >> 24) & 0xff )) \
    $(( (bits >> 16) & 0xff )) \
    $(( (bits >> 8)  & 0xff )) \
    $(( bits & 0xff ))
